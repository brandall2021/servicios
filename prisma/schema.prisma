generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  CLIENT
  PROVIDER
  ADMIN
}

enum TipoFoto {
  SERVICIO
  PERFIL
  OPINION
  TRABAJO
}

enum ReportMotivo {
  SPAM
  FALSO
  INADECUADO
  OTRO
}

enum ReportEstado {
  PENDIENTE
  REVISADO
  RESUELTO
}

enum BudgetStatus {
  PENDIENTE
  COTIZADO
  ACEPTADO
  RECHAZADO
  REVISION
}

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  password      String?
  phone         String?
  image         String?
  role          Role      @default(CLIENT)
  verified      Boolean   @default(false)
  baneado       Boolean   @default(false)
  motivoBaneo   String?
  description   String?
  experience    String?
  certifications String?
  zone          String?
  availability  String?
  whatsapp      String?
  website       String?
  facebook      String?
  instagram     String?
  trabajosRealizados Int @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  servicios    Servicio[]
  opiniones    Opinion[]
  mensajesEnviados   Mensaje[]  @relation("MensajeEmisor")
  mensajesRecibidos  Mensaje[]  @relation("MensajeReceptor")
  fotos            Foto[]     @relation("UserFotos")
  chatsCreados      Chat[]      @relation("ChatCreador")
  chatsParticipante Chat[]      @relation("ChatParticipante")
  reportesHechos    Report[]   @relation("ReportesHechos")
  reportesRecibidos Report[]   @relation("ReportesRecibidos")
  presupuestoSolicitados BudgetRequest[] @relation("BudgetCliente")
  cotizacionesCreadas    BudgetQuote[]   @relation("BudgetProveedor")
  notificaciones         Notification[]

  resetToken            String?  @unique
  resetTokenExpiry      DateTime?
}

model Servicio {
  id          String   @id @default(cuid())
  titulo      String
  descripcion String
  categoria   String
  precio      Float?
  precioTexto String?
  ubicacion   String?
  lat         Float?
  lng         Float?
  disponibilidad String?
  website       String?
  facebook      String?
  instagram     String?
  activo      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  usuarioId   String
  usuario     User     @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  fotos       Foto[]
  opiniones   Opinion[]
  reportes    Report[]
  presupuestos BudgetRequest[]
}

model Foto {
  id         String   @id @default(cuid())
  archivo    String
  tipo       TipoFoto @default(SERVICIO)
  size       Int?
  mimeType   String?
  createdAt  DateTime @default(now())

  servicioId String?
  servicio   Servicio? @relation(fields: [servicioId], references: [id], onDelete: Cascade)
  opinionId  String?
  opinion    Opinion?  @relation(fields: [opinionId], references: [id], onDelete: Cascade)
  usuarioId  String?
  usuario    User?     @relation("UserFotos", fields: [usuarioId], references: [id], onDelete: SetNull)
}

model Opinion {
  id         String   @id @default(cuid())
  puntuacion Int
  comentario String?
  createdAt  DateTime @default(now())

  servicioId String
  servicio   Servicio @relation(fields: [servicioId], references: [id], onDelete: Cascade)

  clienteId  String
  cliente    User     @relation(fields: [clienteId], references: [id], onDelete: Cascade)

  fotos      Foto[]
  reportes   Report[]
}

model Report {
  id          String       @id @default(cuid())
  motivo      ReportMotivo
  descripcion String?
  estado      ReportEstado @default(PENDIENTE)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  denuncianteId String
  denunciante   User   @relation("ReportesHechos", fields: [denuncianteId], references: [id], onDelete: Cascade)

  servicioId  String?
  servicio    Servicio? @relation(fields: [servicioId], references: [id], onDelete: SetNull)
  opinionId   String?
  opinion     Opinion?  @relation(fields: [opinionId], references: [id], onDelete: SetNull)
  usuarioId   String?
  usuario     User?     @relation("ReportesRecibidos", fields: [usuarioId], references: [id], onDelete: SetNull)
}

model Chat {
  id            String   @id @default(cuid())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  creadorId     String
  creador       User     @relation("ChatCreador", fields: [creadorId], references: [id], onDelete: Cascade)
  participanteId String
  participante  User     @relation("ChatParticipante", fields: [participanteId], references: [id], onDelete: Cascade)

  mensajes      Mensaje[]
}

model Mensaje {
  id        String   @id @default(cuid())
  contenido String?
  imagen    String?
  leido     Boolean  @default(false)
  createdAt DateTime @default(now())

  chatId    String
  chat      Chat     @relation(fields: [chatId], references: [id], onDelete: Cascade)

  emisorId  String
  emisor    User     @relation("MensajeEmisor", fields: [emisorId], references: [id], onDelete: Cascade)
  receptorId String
  receptor  User     @relation("MensajeReceptor", fields: [receptorId], references: [id], onDelete: Cascade)
}

model BudgetRequest {
  id          String       @id @default(cuid())
  description String?
  materiales  String?
  archivos    String?
  status      BudgetStatus @default(PENDIENTE)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  servicioId  String
  servicio    Servicio @relation(fields: [servicioId], references: [id], onDelete: Cascade)

  clienteId   String
  cliente     User     @relation("BudgetCliente", fields: [clienteId], references: [id], onDelete: Cascade)

  cotizaciones BudgetQuote[]
}

model BudgetQuote {
  id          String   @id @default(cuid())
  amount      Float
  breakdown   String?
  notes       String?
  validUntil  DateTime?
  version     Int      @default(1)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  requestId    String
  request      BudgetRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  proveedorId  String
  proveedor    User         @relation("BudgetProveedor", fields: [proveedorId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String   @id @default(cuid())
  type      String
  title     String
  message   String?
  link      String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
